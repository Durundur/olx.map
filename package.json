{
  "name": "olx.map",
  "version": "1.0.0",
  "description": "Adds a map view to OLX listings",
  "main": "PageContentController.js",
  "scripts": {
    "build": "npx esbuild ./PageContentController.js --bundle --outfile=dist/content.js --format=iife --loader:.css=css --loader:.png=dataurl --loader:.svg=text && npx esbuild ./PageScript.js --bundle --outfile=dist/page-script.js --format=iife",
    "dev": "npm run build -- --watch",
    "format": "npx prettier --write ."
  },
  "author": "Durundur",
  "license": "ISC",
  "dependencies": {
    "leaflet": "1.9.4",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "esbuild": "0.28.0",
    "prettier": "3.8.0"
  }
}
